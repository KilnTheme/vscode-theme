    "tokenColors": [
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment",
                "string.comment"
            ],
            "settings": { "foreground": "#56534b", "fontStyle": "italic" }
        },
        {
            "name": "Default / variable",
            "scope": ["variable", "meta.variable", "source"],
            "settings": { "foreground": "#ececdf" }
        },
        {
            "name": "Variable parameter",
            "scope": ["variable.parameter", "meta.function.parameters"],
            "settings": { "foreground": "#cfccc0" }
        },
        {
            "name": "Language / builtin variable",
            "scope": [
                "variable.language",
                "variable.other.constant",
                "support.variable"
            ],
            "settings": { "foreground": "#d4b0f5" }
        },
        {
            "name": "Keyword / storage / control",
            "scope": [
                "keyword",
                "keyword.control",
                "storage",
                "storage.type",
                "storage.modifier",
                "keyword.operator.new",
                "keyword.operator.expression"
            ],
            "settings": { "foreground": "#c79bf0" }
        },
        {
            "name": "Operator / punctuation",
            "scope": [
                "keyword.operator",
                "punctuation",
                "meta.brace",
                "punctuation.separator",
                "punctuation.terminator"
            ],
            "settings": { "foreground": "#7c786d" }
        },
        {
            "name": "String",
            "scope": [
                "string",
                "punctuation.definition.string",
                "string.quoted"
            ],
            "settings": { "foreground": "#8fae6f" }
        },
        {
            "name": "String escape / regex",
            "scope": [
                "constant.character.escape",
                "string.regexp",
                "constant.other.character-class"
            ],
            "settings": { "foreground": "#6faea0" }
        },
        {
            "name": "Number / constant / boolean",
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language",
                "keyword.other.unit"
            ],
            "settings": { "foreground": "#d97a5f" }
        },
        {
            "name": "Function",
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call.generic",
                "variable.function"
            ],
            "settings": { "foreground": "#d6884a" }
        },
        {
            "name": "Type / class / namespace",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.name.namespace",
                "support.type",
                "support.class",
                "entity.other.inherited-class",
                "storage.type.primitive"
            ],
            "settings": { "foreground": "#7fc06f" }
        },
        {
            "name": "Property / object key",
            "scope": [
                "variable.other.property",
                "variable.other.object.property",
                "meta.object-literal.key",
                "support.type.property-name"
            ],
            "settings": { "foreground": "#cfccc0" }
        },
        {
            "name": "Tag",
            "scope": ["entity.name.tag", "punctuation.definition.tag"],
            "settings": { "foreground": "#d6884a" }
        },
        {
            "name": "Tag attribute",
            "scope": ["entity.other.attribute-name"],
            "settings": { "foreground": "#7fc06f" }
        },
        {
            "name": "Decorator / annotation",
            "scope": [
                "meta.decorator",
                "punctuation.decorator",
                "entity.name.function.decorator"
            ],
            "settings": { "foreground": "#d6884a", "fontStyle": "italic" }
        },
        {
            "name": "Markup heading",
            "scope": [
                "markup.heading",
                "entity.name.section.markdown",
                "punctuation.definition.heading.markdown"
            ],
            "settings": { "foreground": "#d6884a", "fontStyle": "bold" }
        },
        {
            "name": "Markup bold",
            "scope": ["markup.bold"],
            "settings": { "foreground": "#ececdf", "fontStyle": "bold" }
        },
        {
            "name": "Markup italic",
            "scope": ["markup.italic"],
            "settings": { "foreground": "#ececdf", "fontStyle": "italic" }
        },
        {
            "name": "Markup link",
            "scope": ["markup.underline.link", "string.other.link"],
            "settings": { "foreground": "#8fae6f" }
        },
        {
            "name": "Markup code / raw",
            "scope": ["markup.inline.raw", "markup.fenced_code"],
            "settings": { "foreground": "#8fae6f" }
        },
        {
            "name": "Markup list punctuation",
            "scope": [
                "punctuation.definition.list.begin.markdown",
                "markup.list"
            ],
            "settings": { "foreground": "#d6884a" }
        },
        {
            "name": "Invalid",
            "scope": ["invalid", "invalid.illegal"],
            "settings": { "foreground": "#d97a5f" }
        },
        {
            "name": "JSON key",
            "scope": ["support.type.property-name.json"],
            "settings": { "foreground": "#d6884a" }
        },
        {
            "name": "Diff inserted",
            "scope": ["markup.inserted"],
            "settings": { "foreground": "#8fae6f" }
        },
        {
            "name": "Diff deleted",
            "scope": ["markup.deleted"],
            "settings": { "foreground": "#d97a5f" }
        }
    ],
    "semanticTokenColors": {
        "parameter": "#cfccc0",
        "property": "#cfccc0",
        "function": "#d6884a",
        "method": "#d6884a",
        "type": "#7fc06f",
        "class": "#7fc06f",
        "namespace": "#7fc06f",
        "enum": "#7fc06f",
        "enumMember": "#d4b0f5",
        "variable.constant": "#d4b0f5",
        "macro": "#d6884a",
        "*.mutable": { "fontStyle": "underline" }
    }
}
