    "tokenColors": [
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment",
                "string.comment"
            ],
            "settings": {
                "foreground": "#a8a59c",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Default / variable",
            "scope": ["variable", "meta.variable", "source"],
            "settings": {
                "foreground": "#1c1b18"
            }
        },
        {
            "name": "Variable parameter",
            "scope": ["variable.parameter", "meta.function.parameters"],
            "settings": {
                "foreground": "#3a3833"
            }
        },
        {
            "name": "Language / builtin variable",
            "scope": [
                "variable.language",
                "variable.other.constant",
                "support.variable"
            ],
            "settings": {
                "foreground": "#9a5bd0"
            }
        },
        {
            "name": "Keyword / storage / control",
            "scope": [
                "keyword",
                "keyword.control",
                "storage",
                "storage.type",
                "storage.modifier",
                "keyword.operator.new",
                "keyword.operator.expression"
            ],
            "settings": {
                "foreground": "#9a5bd0"
            }
        },
        {
            "name": "Operator / punctuation",
            "scope": [
                "keyword.operator",
                "punctuation",
                "meta.brace",
                "punctuation.separator",
                "punctuation.terminator"
            ],
            "settings": {
                "foreground": "#86837b"
            }
        },
        {
            "name": "String",
            "scope": [
                "string",
                "punctuation.definition.string",
                "string.quoted"
            ],
            "settings": {
                "foreground": "#5f7d4f"
            }
        },
        {
            "name": "String escape / regex",
            "scope": [
                "constant.character.escape",
                "string.regexp",
                "constant.other.character-class"
            ],
            "settings": {
                "foreground": "#3f7d70"
            }
        },
        {
            "name": "Number / constant / boolean",
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language",
                "keyword.other.unit"
            ],
            "settings": {
                "foreground": "#bb4d3a"
            }
        },
        {
            "name": "Function",
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call.generic",
                "variable.function"
            ],
            "settings": {
                "foreground": "#b4622a"
            }
        },
        {
            "name": "Type / class / namespace",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.name.namespace",
                "support.type",
                "support.class",
                "entity.other.inherited-class",
                "storage.type.primitive"
            ],
            "settings": {
                "foreground": "#4f8a4a"
            }
        },
        {
            "name": "Property / object key",
            "scope": [
                "variable.other.property",
                "variable.other.object.property",
                "meta.object-literal.key",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#3a3833"
            }
        },
        {
            "name": "Tag",
            "scope": ["entity.name.tag", "punctuation.definition.tag"],
            "settings": {
                "foreground": "#b4622a"
            }
        },
        {
            "name": "Tag attribute",
            "scope": ["entity.other.attribute-name"],
            "settings": {
                "foreground": "#4f8a4a"
            }
        },
        {
            "name": "Decorator / annotation",
            "scope": [
                "meta.decorator",
                "punctuation.decorator",
                "entity.name.function.decorator"
            ],
            "settings": {
                "foreground": "#b4622a",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markup heading",
            "scope": [
                "markup.heading",
                "entity.name.section.markdown",
                "punctuation.definition.heading.markdown"
            ],
            "settings": {
                "foreground": "#b4622a",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markup bold",
            "scope": ["markup.bold"],
            "settings": {
                "foreground": "#1c1b18",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markup italic",
            "scope": ["markup.italic"],
            "settings": {
                "foreground": "#1c1b18",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markup link",
            "scope": ["markup.underline.link", "string.other.link"],
            "settings": {
                "foreground": "#5f7d4f"
            }
        },
        {
            "name": "Markup code / raw",
            "scope": ["markup.inline.raw", "markup.fenced_code"],
            "settings": {
                "foreground": "#5f7d4f"
            }
        },
        {
            "name": "Markup list punctuation",
            "scope": [
                "punctuation.definition.list.begin.markdown",
                "markup.list"
            ],
            "settings": {
                "foreground": "#b4622a"
            }
        },
        {
            "name": "Invalid",
            "scope": ["invalid", "invalid.illegal"],
            "settings": {
                "foreground": "#bb4d3a"
            }
        },
        {
            "name": "JSON key",
            "scope": ["support.type.property-name.json"],
            "settings": {
                "foreground": "#b4622a"
            }
        },
        {
            "name": "Diff inserted",
            "scope": ["markup.inserted"],
            "settings": {
                "foreground": "#5f7d4f"
            }
        },
        {
            "name": "Diff deleted",
            "scope": ["markup.deleted"],
            "settings": {
                "foreground": "#bb4d3a"
            }
        }
    ],
    "semanticTokenColors": {
        "parameter": "#3a3833",
        "property": "#3a3833",
        "function": "#b4622a",
        "method": "#b4622a",
        "type": "#4f8a4a",
        "class": "#4f8a4a",
        "namespace": "#4f8a4a",
        "enum": "#4f8a4a",
        "enumMember": "#9a5bd0",
        "variable.constant": "#9a5bd0",
        "macro": "#b4622a",
        "*.mutable": {
            "fontStyle": "underline"
        }
    }
}
